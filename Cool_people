<canvas id="c"></canvas>

<script>
const canvas=document.getElementById("c");
const ctx=canvas.getContext("2d");

function resize(){canvas.width=innerWidth;canvas.height=innerHeight}
window.addEventListener("resize",resize);resize();

let mouseX=0,mouseY=0;
window.addEventListener("mousemove",e=>{
mouseX=(e.clientX/innerWidth-.5)*2;
mouseY=(e.clientY/innerHeight-.5)*2;
});

const ORB_COUNT=14;
const orbs=[];

function rand(a,b){return Math.random()*(b-a)+a}

function randomBlue(){
const m=Math.random();
if(m<.33)return`rgb(${rand(0,30)|0},${rand(80,160)|0},255)`
if(m<.66)return`rgb(0,${rand(180,240)|0},255)`
return`rgb(${rand(40,100)|0},${rand(140,200)|0},255)`
}

class Orb{
constructor(){this.reset()}
reset(){
this.x=rand(-300,canvas.width+300)
this.y=rand(-300,canvas.height+300)
this.r=rand(250,520)
this.dx=rand(-.5,.5)
this.dy=rand(-.5,.5)
this.depth=rand(.2,1)
this.color=randomBlue()
this.alpha=0
}

update(){
this.x+=this.dx
this.y+=this.dy
this.alpha=Math.min(this.alpha+.003,1)

if(this.x<-900||this.x>canvas.width+900||this.y<-900||this.y>canvas.height+900){
this.reset()
}
}

draw(){
const px=this.x+mouseX*80*this.depth
const py=this.y+mouseY*80*this.depth
const g=ctx.createRadialGradient(px,py,0,px,py,this.r)
g.addColorStop(0,this.color)
g.addColorStop(1,"transparent")
ctx.globalAlpha=this.alpha
ctx.fillStyle=g
ctx.beginPath()
ctx.arc(px,py,this.r,0,Math.PI*2)
ctx.fill()
ctx.globalAlpha=1
}
}

for(let i=0;i<ORB_COUNT;i++)orbs.push(new Orb())

function loop(){
ctx.clearRect(0,0,canvas.width,canvas.height)
for(const o of orbs){o.update();o.draw()}
requestAnimationFrame(loop)
}

loop();
</script>

